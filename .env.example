# QTS-ARCHITECT — Environment Variables
# Copy to .env and fill in your credentials.
# Never commit the real .env file.

# --- OANDA (Forex + Gold) ---
# Get from: https://www.oanda.com/demo-account/tpa/personal_token
OANDA_API_TOKEN=your-oanda-api-token-here
# Find in: OANDA portal → Manage Funds → Account Details
OANDA_ACCOUNT_ID=001-001-0000000-001

# --- Kraken (Crypto) ---
KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_API_SECRET=your-kraken-api-secret

# --- Alpaca (US Stocks / ETFs) ---
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
